# Environment files
.env
.env.*
!.env.example
backend/.env
frontend/.env

# Dependencies
laravel-api/vendor/
frontend/node_modules/
node_modules/

# Build output
frontend/dist/
dist/
build/

# Laravel generated files
laravel-api/storage/*.key
laravel-api/storage/logs/*.log
laravel-api/storage/framework/cache/*
laravel-api/storage/framework/sessions/*
laravel-api/storage/framework/views/*
laravel-api/bootstrap/cache/*.php
laravel-api/public/storage
laravel-api/database/*.sqlite
laravel-api/database/*.sqlite-*

# Keep Laravel storage folders available
!laravel-api/storage/framework/cache/.gitignore
!laravel-api/storage/framework/sessions/.gitignore
!laravel-api/storage/framework/views/.gitignore
!laravel-api/storage/logs/.gitignore

# Node and package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test and coverage output
coverage/
.nyc_output/
laravel-api/.phpunit.cache/

# Editor and OS files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.bak